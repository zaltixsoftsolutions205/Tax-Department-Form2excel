# ──────────────────────────────────────────────────────────────
# Copy this file to  server/.env  and fill in the values below
# ──────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/association_db
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/association_db
MONGO_URI=mongodb://localhost:27017/association_db

# Google Vision API service-account credentials
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Express server port
PORT=5000

# URL of the React frontend (for CORS)
CLIENT_URL=http://localhost:5173

# Expected membership fee amount in rupees (default 500)
EXPECTED_AMOUNT=500

# UPI payment config — goes in client/.env (Vite reads VITE_* variables)
VITE_UPI_ID=aguru79621@ybl
VITE_UPI_NAME=Union Bank
